# ============================================================================
# DATA FILES (EXCLUDE LARGE GENERATED DATA)
# ============================================================================
# ESG scenarios (large parquet files)
data/esg/*.parquet
data/esg/*.csv
data/esg/*.feather

# Inforce model points (generated)
data/inforce/*.parquet
data/inforce/*.csv

# Liability results (generated)
data/liability_results/*.parquet
data/liability_results/*.csv

# Valuation results (generated)
data/valuation_results/*.parquet
data/valuation_results/*.csv

# Keep sample assumption files but exclude large datasets
data/assumptions/*.parquet
!data/assumptions/*.csv

# Keep directory structure with .gitkeep files
!data/**/.gitkeep

