# Environment configuration for TVOG Model
# Copy this file to .env and update with your actual paths

# Output directory for generated model points and results
OUTPUT_DIR=data/inforce

# ESG scenario data directory (for Moody ESG CSV files)
ESG_DATA_DIR=data/esg_scenarios

# Valuation results directory
VALUATION_OUTPUT_DIR=data/valuation_results

# External valuation engine path (if applicable)
# EXTERNAL_ENGINE_PATH=/path/to/valuation_engine.exe

# Database connection string (placeholder - do not commit real credentials)
# DATABASE_URL=postgresql://user:password@localhost:5432/tvog_db

# API keys (placeholder - do not commit real keys)
# API_KEY=your_api_key_here
